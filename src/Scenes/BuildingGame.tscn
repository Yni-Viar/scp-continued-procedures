[connection signal="gui_input" from="UI/PlayingArea" to="UI" method="_on_playing_area_gui_input"]
[connection signal="pressed" from="UI/HBoxContainer/InventoryButton" to="UI" method="_on_inventory_button_pressed"]
[connection signal="pressed" from="UI/HBoxContainer/SwitchCameraButton" to="UI" method="_on_switch_camera_button_pressed"]
[connection signal="pressed" from="UI/HBoxContainer/CallMtfButton" to="UI" method="_on_call_mtf_button_pressed"]
[connection signal="pressed" from="UI/HBoxContainer/Scp914Button" to="UI" method="_on_scp_914_button_pressed"]
[connection signal="pressed" from="UI/HBoxContainer/ElevatorButton" to="UI" method="_on_elevator_button_pressed"]
[connection signal="pressed" from="UI/Condition/Back" to="UI" method="_on_back_pressed"]
[connection signal="pressed" from="UI/Back" to="UI" method="_on_back_pressed"]
[connection signal="drag_ended" from="UI/Scp914Panel/Scp914Mode" to="UI" method="_on_scp_914_mode_drag_ended"]
[connection signal="pressed" from="UI/Scp914Panel/Refine" to="UI" method="_on_refine_pressed"]
[connection signal="pressed" from="UI/ElevatorMode/ElevatorCall" to="UI" method="_on_elevator_call_pressed"]
